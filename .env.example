OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Text-to-speech (pronunciation). Uses the macOS `say` command — no key needed.
# TUTOR_TTS_VOICE=Anna       # any installed German (de_DE) voice
# TUTOR_TTS_AUTOPLAY=1       # set 0 to generate audio files without playing them
# TUTOR_TTS_DIR=.german_tutor/audio
