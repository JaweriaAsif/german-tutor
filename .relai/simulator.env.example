# Required OpenAI credential for ChatOpenAI.
OPENAI_API_KEY=your-openai-api-key

# Optional model override for the router and specialist agents.
# OPENAI_MODEL=gpt-5.4

# Optional stable learner id for the SQLite progress store used in simulations.
# TUTOR_LEARNER_ID=relai

# Optional stable LangGraph thread id when you want to reuse an existing checkpoint.
# TUTOR_THREAD_ID=relai-thread

# Optional SQLite progress database path.
# TUTOR_DB=.german_tutor/progress.db

# Optional LangGraph checkpoint SQLite database path.
# TUTOR_CHECKPOINT_DB=.german_tutor/graph.db
