# Required model provider credentials.
# OPENAI_API_KEY=sk-your-key

# Optional model override used by the tutor graph.
# OPENAI_MODEL=gpt-5.4

# Optional stable learner id if you want runs to reuse the same learner profile.
# TUTOR_LEARNER_ID=relai-sim

# Optional toggle for auto-playing local TTS output from speak_german.
# TUTOR_TTS_AUTOPLAY=0

# Optional macOS say voice override for local TTS.
# TUTOR_TTS_VOICE=Anna

# Optional durable progress database path.
# TUTOR_DB=.relai/simulator/runtime/progress.db

# Optional LangGraph checkpoint database path.
# RELAI_SIMULATOR_CHECKPOINT_DB=.relai/simulator/runtime/graph.db

# Optional directory for synthesized audio files when local TTS is used.
# TUTOR_TTS_DIR=.relai/simulator/runtime/audio
