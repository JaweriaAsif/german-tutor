# Required model provider credential.
OPENAI_API_KEY=<set-me>

# Optional model override. Defaults to gpt-5.4 in the project code.
# OPENAI_MODEL=gpt-5.4

# Optional stable learner id used by the tutor's persisted learner profile.
# TUTOR_LEARNER_ID=relai-simulator

# Optional SQLite progress database path.
# TUTOR_DB=.german_tutor/progress.db

# Optional fixed LangGraph thread id for tests that need stable graph-session replay.
# RELAI_SIMULATOR_THREAD_ID=relai-sim-thread

# Optional SQLite checkpoint path for LangGraph conversation state.
# RELAI_SIMULATOR_CHECKPOINT_DB=.german_tutor/graph.db
